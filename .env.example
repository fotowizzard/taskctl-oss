# taskctl optional configuration — copy to .env, fill in if you use a tracker/engine.
# All values here are PLACEHOLDERS. Never commit a real .env.

# --- Repo under orchestration (optional; taskctl.config.json repoPath also works) ---
REPO_PATH=/absolute/path/to/your/target/repo

# --- Jira tracker (OPTIONAL — taskctl defaults to the local tracker; leave blank to skip) ---
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=__REPLACE_WITH_YOUR_JIRA_API_TOKEN__
JIRA_PROJECT_KEY=ABC

# --- Engine notes ---
# taskctl shells out to your installed coding-agent CLIs (e.g. claude, codex); it does NOT
# read engine API keys from here — those are configured in each engine's own CLI.
